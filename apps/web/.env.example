# ─── Database ──────────────────────────────────────────────
# Production: your production Postgres URL (Neon, etc.)
DATABASE_URL="postgresql://..."

# ─── Authentication (Better-Auth) ──────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="..."
# Production: https://supercli.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth (from https://github.com/settings/developers)
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# ─── App URLs ──────────────────────────────────────────────
# Production: https://supercli.vercel.app
NEXT_PUBLIC_APP_BASE_URL="http://localhost:3000"
# Production: https://supercli.vercel.app
NEXT_PUBLIC_APP_URL="https://supercli.vercel.app"

# Terminal server (Express backend for analytics, CLI auth, etc.)
# Production: https://your-terminal-server.onrender.com
TERMINAL_SERVER_URL="http://localhost:3004"

# ─── Vector Search (Pinecone) ──────────────────────────────
PINECONE_DB_API_KEY="pcsk_..."

# ─── AI Providers ──────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSy..."
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (Nodemailer/SMTP) ───────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="..."
SMTP_PASS="..."
EMAIL_FROM="..."
RESEND_ADMIN_EMAIL="..."
