{
  "name": "supercode-cli-server",
  "version": "1.0.0",
  "main": "src/index.ts",
  "bin": {
    "supercode": "./src/cli/main.ts"
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "cli": "bun src/cli/commands/index.ts",
    "login": "bun src/cli/commands/login.ts",
    "start": "bun src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "postinstall": "bun run db:generate"
  },
  "nodemonConfig": {
    "watch": ["src"],
    "ext": "ts,json",
    "exec": "bun src/index.ts",
    "ignore": ["node_modules"]
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@clack/prompts": "^1.5.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@openrouter/sdk": "^0.12.79",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.195",
    "api": "^6.1.3",
    "better-auth": "^1.5.5",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "figlet": "^1.11.0",
    "json-schema-to-ts": "^2.8.0-beta.0",
    "marked": "^18.0.4",
    "marked-terminal": "^7.3.0",
    "oas": "^34.0.1",
    "open": "^11.0.0",
    "pg": "^8.20.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "yocto-spinner": "^1.2.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "nodemon": "^3.1.0",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
