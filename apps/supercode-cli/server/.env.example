# ─── Database ──────────────────────────────────────────────
# Terminal server uses DATABASE_URL_TERMINAL first, falls back to DATABASE_URL
# Production: your Neon/Railway Postgres URL
DATABASE_URL_TERMINAL="postgresql://..."
DATABASE_URL="postgresql://..."

# ─── Authentication (Better-Auth) ──────────────────────────
BETTER_AUTH_SECRET="..."
# Production: URL of the deployed terminal server
BETTER_AUTH_URL="http://localhost:3004"
# Client URL (dashboard/frontend)
CLIENT_URL="http://localhost:3000"

# GitHub OAuth
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# ─── Server ────────────────────────────────────────────────
PORT=10000
# CLI auth URL (used by login command)
SUPERCODE_SERVER_URL="http://localhost:10000"
# Default workspace root for file operations
SUPERCODE_WORKSPACE_ROOT=""

# ─── AI Providers ──────────────────────────────────────────
# Google / Gemini
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSy..."
MODEL1="gemini-2.5-flash"

# OpenRouter
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_MODEL="moonshotai/kimi-k2.6"
OPENROUTER_SITE_URL=""
OPENROUTER_SITE_TITLE="supercode"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# NVIDIA
NVIDIA_API_KEY="nvapi-..."
NVIDIA_MODEL="minimaxai/minimax-m2.7"

# MiniMax
MINIMAX_API_KEY="..."
MINIMAX_MODEL="MiniMax-M2"

# ConcentrateAI
CONCENTRATEAI_API_KEY="..."

# Google Custom Search (for web search tool)
GOOGLE_API_KEY="AIzaSy..."
GOOGLE_CSE_ID="..."
