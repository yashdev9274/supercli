# ──────────────────────────────────────────────
# Supercode CLI Server — Environment Variables
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
#
# 🔴  Required — server won't start without it
# 🟡  Required for feature
# ⚪  Optional — skip if you don't need the feature
#
# ─── Database ──────────────────────────────────
# 🔴 PostgreSQL connection string
# Terminal server uses DATABASE_URL_TERMINAL first, falls back to DATABASE_URL
# Docker Desktop: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL_TERMINAL="postgresql://postgres:postgres@localhost:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ─── Authentication (Better-Auth) ──────────────
# 🔴 Session encryption secret
BETTER_AUTH_SECRET=""
# 🔴 Server URL for auth flows
BETTER_AUTH_URL="http://localhost:3004"
# 🔴 Dashboard/frontend URL (used for CORS, redirects)
CLIENT_URL="http://localhost:3000"

# 🟡 GitHub OAuth — required to log in
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Server ────────────────────────────────────
# ⚪ Port (defaults to 10000 if unset)
PORT=10000
# 🔴 CLI auth URL (used by `supercode login`)
SUPERCODE_SERVER_URL="http://localhost:10000"
# ⚪ Default workspace root for file operations
SUPERCODE_WORKSPACE_ROOT=""

# ─── AI Providers ──────────────────────────────
# 🟡 At least one required for AI features

# Google / Gemini
GOOGLE_GENERATIVE_AI_API_KEY=""
MODEL1="gemini-2.5-flash"

# OpenRouter
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="moonshotai/kimi-k2.6"
# ⚪ Optional: site identity sent with OpenRouter requests
OPENROUTER_SITE_URL=""
OPENROUTER_SITE_TITLE="supercode"

# Anthropic
ANTHROPIC_API_KEY=""

# NVIDIA
NVIDIA_API_KEY=""
NVIDIA_MODEL="minimaxai/minimax-m2.7"

# MiniMax
MINIMAX_API_KEY=""
MINIMAX_MODEL="MiniMax-M2"

# ConcentraceAI
CONCENTRATEAI_API_KEY=""

# ─── Web Search Tools ──────────────────────────
# 🟡 Required for search/scrape tools

# Google Custom Search
GOOGLE_API_KEY=""
GOOGLE_CSE_ID=""

# Firecrawl
FIRECRAWL_API_KEY=""
